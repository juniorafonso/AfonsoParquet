<% layout('admin/layout-admin') %>

<div class="d-flex justify-content-between align-items-center mb-4">
  <h1 class="h3 mb-0">Manage Projects</h1>
  <a href="/admin/projects/new" class="btn btn-primary">
    <i class="fas fa-plus me-2"></i>New Project
  </a>
</div>

<% if (projects.length === 0) { %>
<div class="card">
  <div class="card-body text-center py-5 text-muted">
    <i class="fas fa-images fa-3x mb-3"></i>
    <p>No projects yet. Create your first project!</p>
    <a href="/admin/projects/new" class="btn btn-primary">
      <i class="fas fa-plus me-2"></i>New Project
    </a>
  </div>
</div>
<% } else { %>
<div class="card">
  <div class="card-body p-0">
    <div class="table-responsive">
      <table class="table table-hover mb-0">
        <thead class="table-light">
          <tr>
            <th width="80">Order</th>
            <th>Image</th>
            <th>Title (FR)</th>
            <th>Title (EN)</th>
            <th>Category</th>
            <th width="100">Published</th>
            <th width="150">Actions</th>
          </tr>
        </thead>
        <tbody>
          <% projects.forEach(project => { %>
          <tr>
            <td class="align-middle">
              <span class="badge bg-secondary"><%= project.order %></span>
            </td>
            <td class="align-middle">
              <% if (project.imagePath) { %>
              <img src="<%= project.imagePath %>" alt="<%= project.titleFr %>" class="img-thumbnail" style="width: 60px; height: 60px; object-fit: cover;">
              <% } else { %>
              <div class="bg-light d-inline-flex align-items-center justify-content-center" style="width: 60px; height: 60px;">
                <i class="fas fa-image text-muted"></i>
              </div>
              <% } %>
            </td>
            <td class="align-middle"><%= project.titleFr %></td>
            <td class="align-middle"><%= project.titleEn %></td>
            <td class="align-middle">
              <span class="badge bg-info"><%= project.category %></span>
            </td>
            <td class="align-middle">
              <% if (project.published) { %>
              <span class="badge bg-success">Yes</span>
              <% } else { %>
              <span class="badge bg-secondary">No</span>
              <% } %>
            </td>
            <td class="align-middle">
              <a href="/admin/projects/<%= project.id %>/edit" class="btn btn-sm btn-outline-primary">
                <i class="fas fa-edit"></i>
              </a>
              <button class="btn btn-sm btn-outline-danger" onclick="deleteProject(<%= project.id %>)">
                <i class="fas fa-trash"></i>
              </button>
            </td>
          </tr>
          <% }); %>
        </tbody>
      </table>
    </div>
  </div>
</div>
<% } %>

<script>
  async function deleteProject(id) {
    if (!confirm('Are you sure you want to delete this project?')) {
      return;
    }
    
    try {
      const response = await fetch(`/admin/projects/${id}/delete`, {
        method: 'POST'
      });
      
      if (response.ok) {
        location.reload();
      } else {
        alert('Error deleting project');
      }
    } catch (error) {
      console.error('Error:', error);
      alert('Error deleting project');
    }
  }
</script>
