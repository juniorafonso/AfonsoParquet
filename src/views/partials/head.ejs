<%
/**
 * SEO Head Partial
 * 
 * Required locals:
 * - pageTitle: Page-specific title (without site name)
 * - pageDescription: Page-specific description
 * - pageType: 'website', 'article', etc. (for Open Graph)
 * - canonicalPath: Path without locale (from locale middleware)
 * - jsonLd: Optional array of JSON-LD schemas
 * - ogImage: Optional custom OG image (defaults to /images/og-image.jpg)
 * - noindex: Optional boolean to prevent indexing
 */

const baseUrl = env.BASE_URL;

// Generate full title
const fullTitle = (typeof pageTitle !== 'undefined' && pageTitle) ? `${pageTitle} | Afonso Parquet` : t('site.title');

// Generate canonical URL
const canonicalUrl = `${baseUrl}/${locale}${canonicalPath}`;

// Generate hreflang links
const hreflangLinks = [
  { hreflang: 'fr-CH', href: `${baseUrl}/fr${canonicalPath}` },
  { hreflang: 'en-CH', href: `${baseUrl}/en${canonicalPath}` },
  { hreflang: 'x-default', href: `${baseUrl}/fr${canonicalPath}` }
];

// Open Graph image
const ogImageUrl = (typeof ogImage !== 'undefined' && ogImage) ? ogImage : `${baseUrl}/images/og-image.jpg`;
%>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<meta http-equiv="X-UA-Compatible" content="IE=edge">

<!-- Primary Meta Tags -->
<title><%= fullTitle %></title>
<meta name="title" content="<%= fullTitle %>">
<meta name="description" content="<%= (typeof pageDescription !== 'undefined' && pageDescription) ? pageDescription : t('site.description') %>">
<meta name="keywords" content="<%= t('site.keywords') %>">
<% if (typeof noindex !== 'undefined' && noindex) { %>
<meta name="robots" content="noindex, nofollow">
<% } else { %>
<meta name="robots" content="index, follow">
<% } %>

<!-- Language and Locale -->
<meta http-equiv="content-language" content="<%= locale === 'fr' ? 'fr-CH' : 'en-CH' %>">

<!-- Canonical URL -->
<link rel="canonical" href="<%= canonicalUrl %>">

<!-- Hreflang Tags -->
<% hreflangLinks.forEach(link => { %>
<link rel="alternate" hreflang="<%= link.hreflang %>" href="<%= link.href %>">
<% }); %>

<!-- Open Graph / Facebook -->
<meta property="og:type" content="<%= (typeof pageType !== 'undefined' && pageType) ? pageType : 'website' %>">
<meta property="og:url" content="<%= canonicalUrl %>">
<meta property="og:title" content="<%= fullTitle %>">
<meta property="og:description" content="<%= (typeof pageDescription !== 'undefined' && pageDescription) ? pageDescription : t('site.description') %>">
<meta property="og:image" content="<%= ogImageUrl %>">
<meta property="og:image:alt" content="<%= (typeof pageTitle !== 'undefined' && pageTitle) ? pageTitle : 'Afonso Parquet' %>">
<meta property="og:locale" content="<%= locale === 'fr' ? 'fr_CH' : 'en_CH' %>">
<meta property="og:locale:alternate" content="<%= locale === 'fr' ? 'en_CH' : 'fr_CH' %>">
<meta property="og:site_name" content="Afonso Parquet">

<!-- Twitter Card -->
<meta name="twitter:card" content="summary_large_image">
<meta name="twitter:url" content="<%= canonicalUrl %>">
<meta name="twitter:title" content="<%= fullTitle %>">
<meta name="twitter:description" content="<%= (typeof pageDescription !== 'undefined' && pageDescription) ? pageDescription : t('site.description') %>">
<meta name="twitter:image" content="<%= ogImageUrl %>">

<!-- Favicon -->
<link rel="icon" type="image/x-icon" href="/images/favicon.ico">
<link rel="apple-touch-icon" sizes="180x180" href="/images/apple-touch-icon.png">
<link rel="icon" type="image/png" sizes="32x32" href="/images/favicon-32x32.png">
<link rel="icon" type="image/png" sizes="16x16" href="/images/favicon-16x16.png">

<!-- Webmaster Verification Tags (set in .env) -->
<% if (env.GOOGLE_SITE_VERIFICATION) { %>
<meta name="google-site-verification" content="<%= env.GOOGLE_SITE_VERIFICATION %>">
<% } %>
<% if (env.BING_SITE_VERIFICATION) { %>
<meta name="msvalidate.01" content="<%= env.BING_SITE_VERIFICATION %>">
<% } %>

<!-- JSON-LD Structured Data -->
<% if (typeof jsonLd !== 'undefined' && jsonLd && jsonLd.length > 0) { %>
  <% jsonLd.forEach(schema => { %>
<script type="application/ld+json">
<%- JSON.stringify(schema, null, 2) %>
</script>
  <% }); %>
<% } %>

<!-- Bootstrap 5 CSS -->
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-T3c6CoIi6uLrA9TneNEoa7RxnatzjcDSCmG1MXxSR1GAsXEV/Dwwykc2MPK8M2HN" crossorigin="anonymous">

<!-- Font Awesome -->
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" integrity="sha512-DTOQO9RWCH3ppGqcWaEA1BIZOC6xxalwEsw9c2QQeAIftl+Vegovlnee1c9QX4TctnWMn13TZye+giMm8e2LwA==" crossorigin="anonymous" referrerpolicy="no-referrer">

<!-- intl-tel-input CSS (for phone input) -->
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/intl-tel-input@24.8.2/build/css/intlTelInput.css">

<!-- Custom CSS -->
<link rel="stylesheet" href="/css/style.css">
