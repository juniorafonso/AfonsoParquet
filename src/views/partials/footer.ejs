<%
/**
 * Footer Partial
 * Company info, links, social media
 */
const currentYear = new Date().getFullYear();
%>
<footer class="bg-dark text-white pt-5 pb-3 mt-5">
  <div class="container">
    <div class="row">
      
      <!-- Company Info -->
      <div class="col-md-4 mb-4">
        <h5 class="fw-bold"><%= t('footer.company') %></h5>
        <p class="text-muted">
          <%= t('footer.description') %>
        </p>
        <% if (env.COMPANY_PHONE) { %>
        <p>
          <i class="fas fa-phone me-2"></i>
          <a href="tel:<%= env.COMPANY_PHONE %>" class="text-white text-decoration-none">
            <%= env.COMPANY_PHONE %>
          </a>
        </p>
        <% } %>
        <% if (process.env.ADMIN_EMAIL) { %>
        <p>
          <i class="fas fa-envelope me-2"></i>
          <a href="mailto:<%= process.env.ADMIN_EMAIL %>" class="text-white text-decoration-none">
            <%= process.env.ADMIN_EMAIL %>
          </a>
        </p>
        <% } %>
      </div>
      
      <!-- Quick Links -->
      <div class="col-md-4 mb-4">
        <h5 class="fw-bold"><%= t('nav.services') %></h5>
        <ul class="list-unstyled">
          <li class="mb-2">
            <a href="<%= url('/services#poncage') %>" class="text-white text-decoration-none">
              <%= t('services.poncage.title') %>
            </a>
          </li>
          <li class="mb-2">
            <a href="<%= url('/services#pose') %>" class="text-white text-decoration-none">
              <%= t('services.pose.title') %>
            </a>
          </li>
          <li class="mb-2">
            <a href="<%= url('/services#plinthe') %>" class="text-white text-decoration-none">
              <%= t('services.plinthe.title') %>
            </a>
          </li>
          <li class="mb-2">
            <a href="<%= url('/services#reparation') %>" class="text-white text-decoration-none">
              <%= t('services.reparation.title') %>
            </a>
          </li>
          <li class="mb-2">
            <a href="<%= url('/services#vitrification') %>" class="text-white text-decoration-none">
              <%= t('services.vitrification.title') %>
            </a>
          </li>
        </ul>
      </div>
      
      <!-- Legal & Social -->
      <div class="col-md-4 mb-4">
        <h5 class="fw-bold"><%= t('footer.followUs') %></h5>
        <div class="mb-3">
          <% if (env.FACEBOOK_URL) { %>
          <a href="<%= env.FACEBOOK_URL %>" target="_blank" rel="noopener noreferrer" class="text-white me-3" aria-label="Facebook">
            <i class="fab fa-facebook fa-2x"></i>
          </a>
          <% } %>
          <% if (env.INSTAGRAM_URL) { %>
          <a href="<%= env.INSTAGRAM_URL %>" target="_blank" rel="noopener noreferrer" class="text-white me-3" aria-label="Instagram">
            <i class="fab fa-instagram fa-2x"></i>
          </a>
          <% } %>
        </div>
        
        <ul class="list-unstyled">
          <li class="mb-2">
            <a href="<%= url('/legal') %>" class="text-muted text-decoration-none">
              <%= t('footer.legal') %>
            </a>
          </li>
          <li class="mb-2">
            <a href="<%= url('/privacy') %>" class="text-muted text-decoration-none">
              <%= t('footer.privacy') %>
            </a>
          </li>
        </ul>
      </div>
      
    </div>
    
    <hr class="border-secondary">
    
    <div class="row">
      <div class="col-12 text-center text-muted">
        <p class="mb-0">
          &copy; <%= currentYear %> <%= t('footer.company') %>. <%= t('footer.rights') %>.
        </p>
      </div>
    </div>
  </div>
</footer>
