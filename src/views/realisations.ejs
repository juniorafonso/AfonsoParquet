<% layout('layout') %>

<div class="container my-5">
  <div class="text-center mb-5">
    <h1 class="fw-bold"><%= t('home.realisations.title') %></h1>
    <p class="lead text-muted"><%= t('home.realisations.subtitle') %></p>
  </div>
  
  <div class="row g-4">
    <% if (projects && projects.length > 0) { %>
      <% projects.forEach(project => { %>
      <div class="col-md-6 col-lg-4">
        <div class="card h-100 shadow-sm">
          <% if (project.imagePath) { %>
          <img src="<%= project.imagePath %>" class="card-img-top" alt="<%= locale === 'fr' ? project.titleFr : project.titleEn %>" style="height: 250px; object-fit: cover;">
          <% } %>
          <div class="card-body">
            <% if (project.category) { %>
            <span class="badge bg-primary mb-2"><%= project.category %></span>
            <% } %>
            <h5 class="card-title"><%= locale === 'fr' ? project.titleFr : project.titleEn %></h5>
            <p class="card-text text-muted">
              <%= (locale === 'fr' ? project.descFr : project.descEn).substring(0, 120) %>...
            </p>
            <a href="<%= url('/realisations/' + project.id) %>" class="btn btn-outline-primary">
              <%= t('common.readMore') %>
            </a>
          </div>
        </div>
      </div>
      <% }); %>
    <% } else { %>
      <div class="col-12 text-center">
        <div class="alert alert-info">
          <i class="fas fa-info-circle me-2"></i>
          <%= locale === 'fr' ? 'Aucun projet disponible pour le moment.' : 'No projects available at the moment.' %>
        </div>
      </div>
    <% } %>
  </div>
  
  <!-- CTA -->
  <div class="text-center mt-5 bg-light p-5 rounded">
    <h3 class="fw-bold mb-3"><%= t('home.cta.title') %></h3>
    <p class="lead mb-4"><%= t('home.cta.subtitle') %></p>
    <a href="<%= url('/devis') %>" class="btn btn-primary btn-lg">
      <i class="fas fa-file-invoice me-2"></i><%= t('home.cta.button') %>
    </a>
  </div>
</div>
