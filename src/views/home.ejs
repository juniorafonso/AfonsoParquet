<% layout('layout') %>

<!-- Hero Section -->
<section class="hero bg-primary text-white text-center py-5">
  <div class="container py-5">
    <h1 class="display-4 fw-bold mb-3">
      <%= t('home.hero.title') %>
    </h1>
    <p class="lead mb-4">
      <%= t('home.hero.subtitle') %>
    </p>
    <a href="<%= url('/devis') %>" class="btn btn-light btn-lg">
      <i class="fas fa-file-invoice me-2"></i><%= t('home.hero.cta') %>
    </a>
  </div>
</section>

<!-- Services Section -->
<section class="services py-5">
  <div class="container">
    <div class="text-center mb-5">
      <h2 class="fw-bold"><%= t('home.services.title') %></h2>
      <p class="text-muted"><%= t('home.services.subtitle') %></p>
    </div>
    
    <div class="row g-4">
      <!-- Ponçage -->
      <div class="col-md-6 col-lg-4">
        <div class="card h-100 shadow-sm">
          <div class="card-body text-center">
            <i class="fas fa-tools fa-3x text-primary mb-3"></i>
            <h5 class="card-title fw-bold"><%= t('services.poncage.title') %></h5>
            <p class="card-text text-muted"><%= t('services.poncage.desc') %></p>
            <a href="<%= url('/services#poncage') %>" class="btn btn-outline-primary">
              <%= t('common.readMore') %>
            </a>
          </div>
        </div>
      </div>
      
      <!-- Pose de Parquet -->
      <div class="col-md-6 col-lg-4">
        <div class="card h-100 shadow-sm">
          <div class="card-body text-center">
            <i class="fas fa-th-large fa-3x text-primary mb-3"></i>
            <h5 class="card-title fw-bold"><%= t('services.pose.title') %></h5>
            <p class="card-text text-muted"><%= t('services.pose.desc') %></p>
            <a href="<%= url('/services#pose') %>" class="btn btn-outline-primary">
              <%= t('common.readMore') %>
            </a>
          </div>
        </div>
      </div>
      
      <!-- Pose de Plinthe -->
      <div class="col-md-6 col-lg-4">
        <div class="card h-100 shadow-sm">
          <div class="card-body text-center">
            <i class="fas fa-ruler-combined fa-3x text-primary mb-3"></i>
            <h5 class="card-title fw-bold"><%= t('services.plinthe.title') %></h5>
            <p class="card-text text-muted"><%= t('services.plinthe.desc') %></p>
            <a href="<%= url('/services#plinthe') %>" class="btn btn-outline-primary">
              <%= t('common.readMore') %>
            </a>
          </div>
        </div>
      </div>
      
      <!-- Réparation -->
      <div class="col-md-6 col-lg-4">
        <div class="card h-100 shadow-sm">
          <div class="card-body text-center">
            <i class="fas fa-wrench fa-3x text-primary mb-3"></i>
            <h5 class="card-title fw-bold"><%= t('services.reparation.title') %></h5>
            <p class="card-text text-muted"><%= t('services.reparation.desc') %></p>
            <a href="<%= url('/services#reparation') %>" class="btn btn-outline-primary">
              <%= t('common.readMore') %>
            </a>
          </div>
        </div>
      </div>
      
      <!-- Vitrification -->
      <div class="col-md-6 col-lg-4">
        <div class="card h-100 shadow-sm">
          <div class="card-body text-center">
            <i class="fas fa-shield-alt fa-3x text-primary mb-3"></i>
            <h5 class="card-title fw-bold"><%= t('services.vitrification.title') %></h5>
            <p class="card-text text-muted"><%= t('services.vitrification.desc') %></p>
            <a href="<%= url('/services#vitrification') %>" class="btn btn-outline-primary">
              <%= t('common.readMore') %>
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Réalisations Section (will load from database) -->
<section class="realisations bg-light py-5">
  <div class="container">
    <div class="text-center mb-5">
      <h2 class="fw-bold"><%= t('home.realisations.title') %></h2>
      <p class="text-muted"><%= t('home.realisations.subtitle') %></p>
    </div>
    
    <!-- Projects will be loaded from controller -->
    <div class="row g-4">
      <% if (typeof projects !== 'undefined' && projects.length > 0) { %>
        <% projects.slice(0, 3).forEach(project => { %>
        <div class="col-md-6 col-lg-4">
          <div class="card h-100 shadow-sm">
            <% if (project.imagePath) { %>
            <img src="<%= project.imagePath %>" class="card-img-top" alt="<%= locale === 'fr' ? project.titleFr : project.titleEn %>">
            <% } %>
            <div class="card-body">
              <h5 class="card-title"><%= locale === 'fr' ? project.titleFr : project.titleEn %></h5>
              <p class="card-text text-muted"><%= (locale === 'fr' ? project.descFr : project.descEn).substring(0, 100) %>...</p>
              <a href="<%= url('/realisations/' + project.id) %>" class="btn btn-outline-primary">
                <%= t('common.readMore') %>
              </a>
            </div>
          </div>
        </div>
        <% }); %>
      <% } else { %>
        <div class="col-12 text-center text-muted">
          <p><%= locale === 'fr' ? 'Projets bientôt disponibles.' : 'Projects coming soon.' %></p>
        </div>
      <% } %>
    </div>
    
    <div class="text-center mt-4">
      <a href="<%= url('/realisations') %>" class="btn btn-primary">
        <%= t('home.realisations.viewAll') %>
      </a>
    </div>
  </div>
</section>

<!-- CTA Section -->
<section class="cta bg-primary text-white text-center py-5">
  <div class="container py-4">
    <h2 class="fw-bold mb-3"><%= t('home.cta.title') %></h2>
    <p class="lead mb-4"><%= t('home.cta.subtitle') %></p>
    <a href="<%= url('/devis') %>" class="btn btn-light btn-lg">
      <i class="fas fa-file-invoice me-2"></i><%= t('home.cta.button') %>
    </a>
  </div>
</section>
