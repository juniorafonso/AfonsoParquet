# Server Configuration
NODE_ENV=production
PORT=3000
BASE_URL=https://afonsoparquet.ch

# Session Secret (generate a strong random string)
SESSION_SECRET=your-super-secret-session-key-change-this

# Database (SQLite - path relative to project root)
DB_PATH=./data/database.sqlite

# Admin User (used only for initial seed if User table is empty)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-strong-password

# SMTP Configuration (leave empty if not configured yet)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM_NAME=Afonso Parquet
SMTP_FROM_EMAIL=contact@afonsoparquet.ch

# Email notification (admin receives devis notifications)
ADMIN_EMAIL=admin@afonsoparquet.ch

# Analytics (leave empty if not configured yet)
GA4_MEASUREMENT_ID=
META_PIXEL_ID=

# SEO & Webmaster Tools
GOOGLE_SITE_VERIFICATION=
BING_SITE_VERIFICATION=

# Company Contact (used in schema.org structured data)
COMPANY_PHONE=+41123456789

# Cloudflare Turnstile (leave empty if not configured yet)
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Social Media (placeholder URLs)
INSTAGRAM_URL=https://instagram.com/afonsoparquet
FACEBOOK_URL=https://facebook.com/afonsoparquet

# Upload Limits
MAX_FILE_SIZE_MB=100
MAX_PHOTOS_PER_DEVIS=10
MAX_VIDEOS_PER_DEVIS=2
MAX_TOTAL_SIZE_MB=250
